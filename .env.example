# Flask Configuration
FLASK_ENV=development
SECRET_KEY=geowatch_secret_key_change_me_in_production

# Database Configuration
# Local SQLite is used by default if DATABASE_URL is not set
# For PostgreSQL: postgresql://username:password@localhost:5432/geowatch
DATABASE_URL=sqlite:///geowatch.db

# Gemini API Configuration (Optional)
# Get a free key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=
